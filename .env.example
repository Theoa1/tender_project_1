# Database — Postgres (cloud). Use Neon, Supabase, Vercel Postgres, Railway, etc.
# Example (Neon): postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Owner login (admin)
OWNER_EMAIL="owner@tenderchildcare.com"
# Generate with: node -e "console.log(require('bcryptjs').hashSync('YourStrongPassword',10))"
OWNER_PASSWORD_HASH=""

# Session signing secret (32+ random chars). Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET="change-me-to-a-long-random-string-please-change"

# SMTP for email + verification codes (required for verification flow)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Tender Child Care <owner@tenderchildcare.com>"
OWNER_NOTIFY_EMAIL="owner@tenderchildcare.com"

# Twilio for SMS + verification codes (required for phone verification)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Verification settings
VERIFICATION_CODE_TTL_MIN="10"
VERIFICATION_MAX_ATTEMPTS="5"

# Public site URL (used in emails)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
